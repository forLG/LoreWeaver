# LoreWeaver Qwen3-8B Configuration
# Copy this file to .env and fill in your values

# LLM API Configuration
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=127.0.0.1:8000
LLM_MODEL=qwen3-8b

# Concurrency Settings
LLM_MAX_CONCURRENT=50
LLM_MAX_TOKENS=8192

# Optional: Repetition penalty for vLLM (1.0 = no penalty)
# LLM_REPETITION_PENALTY=1.0

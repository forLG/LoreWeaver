# OpenAI-compatible API Configuration
# Get your API key from your LLM provider (OpenAI, DeepSeek, etc.)

# API Key (required)
OPENAI_API_KEY=sk-your-api-key-here

# Base URL (optional - defaults to https://api.openai.com/v1)
# For DeepSeek: https://api.deepseek.com
# For local vLLM: http://localhost:8000/v1
# For OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name (optional - defaults to gpt-4o)
# Common options: gpt-4o, gpt-4o-mini, deepseek-chat, qwen2.5-7b-instruct, qwen3-8b
LLM_MODEL=gpt-4o

# Maximum concurrent requests (optional - auto-detected based on model)
# Cloud APIs: 50-100
# Local vLLM: 5-10 (adjust based on your GPU memory)
#LLM_MAX_CONCURRENT=10

# Maximum tokens per LLM response (optional - for small models only)
# Large models (GPT-4, DeepSeek): Leave empty (no artificial limit)
# Small models (Qwen3-8B): Set to 2048-4096 to prevent repetition loops
# If not set, models generate until naturally complete
LLM_MAX_TOKENS=2048

# Neo4j Configuration (optional - used by build_graph.py scripts)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

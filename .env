# OpenAI-compatible API Configuration
# Get your API key from your LLM provider (OpenAI, DeepSeek, etc.)

# API Key (required)
OPENAI_API_KEY=sk-dc0a809311a840459553ad6dd9607c3f

# Base URL
# For DeepSeek: https://api.deepseek.com
# For local vLLM: http://localhost:8000/v1
# For OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.deepseek.com

# Model name
# Common options: deepseek-chat, gpt-4o, qwen2.5-7b-instruct
LLM_MODEL=deepseek-chat

# Maximum tokens for LLM responses
# Larger models (GPT-4): 4096-8192 is sufficient
# Smaller models (qwen, deepseek): 8192-16384 recommended for complex JSON

# Maximum concurrent requests
# Cloud APIs: 50-100
# Local vLLM: 5-10 (adjust based on your GPU memory)
LLM_MAX_CONCURRENT=10

# Maximum tokens per LLM response (for small models only)
# Set to 2048-4096 for Qwen3-8B to prevent repetition loops
LLM_MAX_TOKENS=2048

# Repetition penalty (for vLLM only, to reduce output repetition)
# 1.0 = no penalty, 1.1-1.5 = moderate penalty (recommended for Qwen3)
# Leave empty for cloud APIs or models without repetition issues
LLM_REPETITION_PENALTY=1.2

# Neo4j Configuration (optional - used by build_graph.py scripts)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
